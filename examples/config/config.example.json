{
  "schemaVersion": 1,
  "storage": {
    "dataDir": "%LOCALAPPDATA%\\io.github.wenlei0603.time-state-recorder-desktop\\data",
    "databasePath": "%LOCALAPPDATA%\\io.github.wenlei0603.time-state-recorder-desktop\\data\\local.sqlite3",
    "screenshotDir": "%LOCALAPPDATA%\\io.github.wenlei0603.time-state-recorder-desktop\\data\\screenshots",
    "highResScreenshotDir": "%LOCALAPPDATA%\\io.github.wenlei0603.time-state-recorder-desktop\\data\\high-res-screenshots",
    "retentionDays": 30
  },
  "capture": {
    "pollMs": 1000,
    "screenshotIntervalSecs": 60,
    "highResCaptureEnabled": true,
    "inputCaptureEnabled": true,
    "idleThresholdSecs": 120
  },
  "privacy": {
    "defaultPrivacyMode": "redacted",
    "blockerConfigPath": "%LOCALAPPDATA%\\io.github.wenlei0603.time-state-recorder-desktop\\data\\blocker_config.json",
    "externalAiWarningAccepted": false
  },
  "ai": {
    "enabled": false,
    "providerPreset": "customOpenAiCompatible",
    "displayName": "Custom OpenAI-compatible provider",
    "baseUrl": "",
    "model": "gpt-4o-mini",
    "maxCompletionTokens": 200000,
    "visionEnabled": true,
    "pipelines": {
      "visualAnalysis": false,
      "insightReports": false,
      "dailyBrief": false
    }
  },
  "system": {
    "apiPort": 4317,
    "launchOnStartup": false,
    "startMinimized": false,
    "trayEnabled": true
  }
}
