{
  "version": 1,
  "rules": [
    {
      "capture_type": "screenshot",
      "field": "process_name",
      "operator": "equals",
      "value": "Taskmgr.exe"
    },
    {
      "capture_type": "screenshot",
      "field": "window_title",
      "operator": "contains",
      "value": "Banking"
    },
    {
      "capture_type": "text_capture",
      "field": "window_title",
      "operator": "contains",
      "value": "Banking"
    }
  ]
}
